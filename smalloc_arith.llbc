quals `0b11` (i.e., `3`).\npub const SMALLEST_SLOT_SIZE_BITS_MASK: usize =\n    (1usize << SMALLEST_SLOT_SIZE_BITS) - 1;\n\n/// Maps a `(size, alignment)` allocation request to a size class.\n///\n/// Computes `⌊log2( (siz-1) | (ali-1) | mask )⌋ + 1`, which is `⌈log2(x)⌉`\n/// where `x = max(siz, ali, SMALLEST_SLOT_SIZE)`.\n///\n/// Preconditions (debug-asserted in upstream smalloc):\n/// - `siz > 0`\n/// - `ali > 0`\n/// - `ali` is a power of two\n/// - `ali < 2^32`\npub fn reqali_to_sc(siz: usize, ali: usize) -> SizeClass {\n    (((siz - 1) | (ali - 1) | SMALLEST_SLOT_SIZE_BITS_MASK).ilog2() + 1)\n        as SizeClass\n}\n"},{"id":1,"name":{"Local":"/rustc/library/core/src/num/uint_macros.rs"},"crate_name":"core","contents":null},{"id":2,"name":{"Local":"/rustc/library/core/src/num/mod.rs"},"crate_name":"core","contents":null},{"id":3,"name":{"Local":"/rustc/library/core/src/lib.rs"},"crate_name":"core","contents":null}],"item_names":[{"key":{"Type":0},"value":[{"Ident":["smalloc_arith",0]},{"Ident":["SizeClass",0]}]},{"key":{"Global":0},"value":[{"Ident":["smalloc_arith",0]},{"Ident":["SMALLEST_SLOT_SIZE_BITS",0]}]},{"key":{"Global":1},"value":[{"Ident":["smalloc_arith",0]},{"Ident":["SMALLEST_SLOT_SIZE_BITS_MASK",0]}]},{"key":{"Fun":0},"value":[{"Ident":["smalloc_arith",0]},{"Ident":["reqali_to_sc",0]}]},{"key":{"Fun":1},"value":[{"Ident":["smalloc_arith",0]},{"Ident":["SMALLEST_SLOT_SIZE_BITS",0]}]},{"key":{"Fun":2},"value":[{"Ident":["smalloc_arith",0]},{"Ident":["SMALLEST_SLOT_SIZE_BITS_MASK",0]}]},{"key":{"Fun":3},"value":[{"Ident":["core",0]},{"Ident":["num",0]},{"Impl":{"Ty":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"HashConsedValue":[242,{"Literal":{"UInt":"Usize"}}]},"kind":"InherentImplBlock"}}},{"Ident":["ilog2",0]}]}],"assoc_item_names":[],"short_names":[{"key":{"Type":0},"value":[{"Ident":["SizeClass",0]}]},{"key":{"Global":0},"value":[